<?php

namespace App\Repositories;

use App\Models\SizeConversionRule;
use App\Repositories\Interfaces\SizeConversionRuleRepositoryInterface;

class SizeConversionRuleRepository implements SizeConversionRuleRepositoryInterface
{
    protected $model;

    public function __construct(SizeConversionRule $model)
    {
        $this->model = $model;
    }

    public function getAllActive()
    {
        // Lấy các rule đang active, sắp xếp độ ưu tiên từ cao xuống thấp
        return $this->model->where('is_active', true)
                           ->orderBy('priority_level', 'desc')
                           ->get();
    }

    public function findById($id)
    {
        return $this->model->findOrFail($id);
    }

    public function create(array $data)
    {
        return $this->model->create($data);
    }

    public function update($id, array $data)
    {
        $rule = $this->findById($id);
        $rule->update($data);
        return $rule;
    }

    public function delete($id)
    {
        return $this->model->destroy($id);
    }

    public function findMatchingRule($length, $width, $height)
    {
        // Logic tìm rule phù hợp: 
        // Lấy tất cả rule active, sort theo priority, loop check kích thước
        $rules = $this->getAllActive();
        
        foreach ($rules as $rule) {
            if ($length <= $rule->max_length &&
                $width <= $rule->max_width &&
                $height <= $rule->max_height) {
                return $rule;
            }
        }
        
        return null; // Không khớp rule nào
    }
}