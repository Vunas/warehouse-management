erDiagram

%% =============================
%% 1. AUTH & USER
%% =============================

USERS {
    bigint id PK
    string username
    string password
    string full_name
    string email
    string phone
    boolean is_active
    datetime created_at
}

ROLES {
    int id PK
    string role_name
}

PERMISSIONS {
    int id PK
    string permission_code
    string description
}

USER_ROLES {
    bigint user_id FK
    int role_id FK
}

ROLE_PERMISSIONS {
    int role_id FK
    int permission_id FK
}

%% =============================
%% 2. ADDRESS
%% =============================

CITIES {
    int id PK
    string name
}

DISTRICTS {
    int id PK
    int city_id FK
    string name
}

WARDS {
    int id PK
    int district_id FK
    string name
}

ADDRESSES {
    int id PK
    bigint user_id FK
    int ward_id FK
    string detail
}

%% =============================
%% 3. PRODUCT
%% =============================

CATEGORIES {
    int id PK
    string name
}

BRANDS {
    int id PK
    string name
}

PRODUCTS {
    int id PK
    int category_id FK
    int brand_id FK
    string name
    string description
    decimal price
    boolean is_active
}

PRODUCT_IMAGES {
    int id PK
    int product_id FK
    string image_url
}

%% =============================
%% 4. SUPPLIER
%% =============================

SUPPLIERS {
    int id PK
    string name
    string phone
    string email
    string address
}

SUPPLIER_PRODUCTS {
    int supplier_id FK
    int product_id FK
}

%% =============================
%% 5. WAREHOUSE
%% =============================

WAREHOUSES {
    int id PK
    string name
    string location
}

ZONES {
    int id PK
    int warehouse_id FK
    string name
}

SHELVES {
    int id PK
    int zone_id FK
    string shelf_code
}

INVENTORY {
    bigint id PK
    int product_id FK
    int shelf_id FK
    int quantity
}

%% =============================
%% 6. INBOUND
%% =============================

INBOUND_ORDERS {
    bigint id PK
    int supplier_id FK
    bigint staff_id FK
    string status
    datetime created_at
}

INBOUND_ITEMS {
    bigint id PK
    bigint inbound_id FK
    int product_id FK
    int quantity
    decimal price
}

%% =============================
%% 7. OUTBOUND
%% =============================

OUTBOUND_ORDERS {
    bigint id PK
    bigint order_id FK
    bigint staff_id FK
    string status
    datetime created_at
}

OUTBOUND_ITEMS {
    bigint id PK
    bigint outbound_id FK
    int product_id FK
    int quantity
}

%% =============================
%% 8. TRANSFER
%% =============================

STOCK_TRANSFERS {
    bigint id PK
    int from_shelf_id FK
    int to_shelf_id FK
    bigint staff_id FK
    string status
    datetime created_at
}

TRANSFER_ITEMS {
    bigint id PK
    bigint transfer_id FK
    bigint inventory_id FK
    int product_id FK
    int quantity
}

%% =============================
%% 9. SALES
%% =============================

ORDERS {
    bigint id PK
    bigint user_id FK
    int address_id FK
    decimal total_price
    string status
    datetime order_date
}

ORDER_ITEMS {
    bigint id PK
    bigint order_id FK
    int product_id FK
    int quantity
    decimal price
}

PAYMENTS {
    bigint id PK
    bigint order_id FK
    string payment_method
    decimal amount
    string status
}
CART_ITEMS {
    bigint id PK
    bigint user_id FK
    int product_id FK
    int quantity
    datetime created_at
    datetime updated_at
}

%% =============================
%% RELATIONSHIPS
%% =============================

USERS ||--o{ USER_ROLES : has
ROLES ||--o{ USER_ROLES : assigned

ROLES ||--o{ ROLE_PERMISSIONS : has
PERMISSIONS ||--o{ ROLE_PERMISSIONS : granted

CITIES ||--o{ DISTRICTS : contains
DISTRICTS ||--o{ WARDS : contains
WARDS ||--o{ ADDRESSES : contains
USERS ||--o{ ADDRESSES : owns

CATEGORIES ||--o{ PRODUCTS : categorizes
BRANDS ||--o{ PRODUCTS : brands
PRODUCTS ||--o{ PRODUCT_IMAGES : has

SUPPLIERS ||--o{ SUPPLIER_PRODUCTS : supplies
PRODUCTS ||--o{ SUPPLIER_PRODUCTS : supplied_by

WAREHOUSES ||--o{ ZONES : contains
ZONES ||--o{ SHELVES : contains
SHELVES ||--o{ INVENTORY : stores
PRODUCTS ||--o{ INVENTORY : stocked

SUPPLIERS ||--o{ INBOUND_ORDERS : creates
USERS ||--o{ INBOUND_ORDERS : handles
INBOUND_ORDERS ||--o{ INBOUND_ITEMS : contains
PRODUCTS ||--o{ INBOUND_ITEMS : inbounded

ORDERS ||--o{ OUTBOUND_ORDERS : generates
USERS ||--o{ OUTBOUND_ORDERS : handles
OUTBOUND_ORDERS ||--o{ OUTBOUND_ITEMS : contains
PRODUCTS ||--o{ OUTBOUND_ITEMS : outbounded

STOCK_TRANSFERS ||--o{ TRANSFER_ITEMS : contains
USERS ||--o{ STOCK_TRANSFERS : processes

USERS ||--o{ ORDERS : places
ORDERS ||--o{ ORDER_ITEMS : includes
PRODUCTS ||--o{ ORDER_ITEMS : sold

ORDERS ||--|| PAYMENTS : paid

USERS ||--o{ CART_ITEMS : has
PRODUCTS ||--o{ CART_ITEMS : added